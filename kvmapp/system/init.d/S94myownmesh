#!/bin/sh
# S94myownmesh — start the MyOwnMesh daemon for the native AllMyStuff bridge.
#
# Runs BEFORE the NanoKVM server (S95nanokvm) so the daemon's control socket
# ($MYOWNMESH_HOME/daemon.sock) is up by the time the server's mesh bridge tries
# to connect. The bridge is non-fatal and retries, so a slow/absent daemon never
# blocks the KVM — this just gives it the best chance to be ready.
#
# Follows the S95nanokvm pattern: copy the payload out of the read-only /kvmapp
# into /tmp, then launch from there.

MYOWNMESH_HOME=/data/myownmesh
export MYOWNMESH_HOME

# The control socket MUST live on tmpfs. /data is the device's writable data
# partition (typically exFAT/FAT), which can't hold a Unix socket file — bind()
# returns EPERM. Identity/rosters/state are regular files and stay on /data; only
# the socket moves to tmpfs. The Go bridge's mesh.socket default points here too.
RUNTIME_DIR=/tmp/myownmesh
CONTROL_SOCKET=$RUNTIME_DIR/daemon.sock
CONFIG=$MYOWNMESH_HOME/config.json

# Where the daemon binary ships in the app image. Adjust here if the packaging
# location changes; the Go config's mesh.daemonBin should match.
DAEMON_SRC=/kvmapp/system/bin/myownmesh
DAEMON_DST=$RUNTIME_DIR/myownmesh

case "$1" in
  start)
    # Nothing to do if the daemon binary isn't shipped in this image — the KVM
    # server's bridge will simply keep retrying and the device stays LAN-only.
    if [ ! -x "$DAEMON_SRC" ]; then
        echo "myownmesh: daemon binary not found at $DAEMON_SRC; skipping"
        exit 0
    fi

    # The NanoKVM has no battery-backed RTC, so it boots with the clock at 1970.
    # The mesh needs a real clock BEFORE the daemon joins: relays use TLS (a 1970
    # clock rejects their certs as "not valid yet"), and presence/roster/network
    # state is timestamped/signed — joining at 1970 makes peers treat the node as
    # invalid (it shows up but never goes "online"/claimable), and the later NTP
    # jump tears the live connection down. Nudge the clock first, bounded so a
    # missing NTP path never hangs boot.
    if [ "$(date -u +%Y 2>/dev/null)" -lt 2020 ] 2>/dev/null; then
        echo "myownmesh: clock unset ($(date -u)); waiting for NTP…"
        # Kick a one-shot sync if ntpd is available (fast); otherwise just wait
        # for whatever time sync the firmware runs. Wait is bounded so an offline
        # device never hangs boot — it'll come up degraded and recover later.
        if command -v ntpd >/dev/null 2>&1; then
            ntpd -nq -p pool.ntp.org -p time.cloudflare.com -p time.google.com >/dev/null 2>&1 &
            _ntp=$!
        fi
        _i=0
        while [ "$(date -u +%Y 2>/dev/null)" -lt 2020 ] && [ "$_i" -lt 25 ]; do
            sleep 1; _i=$((_i + 1))
        done
        [ -n "${_ntp:-}" ] && kill "$_ntp" 2>/dev/null
        echo "myownmesh: clock now $(date -u)"
    fi

    mkdir -p "$MYOWNMESH_HOME"
    mkdir -p "$RUNTIME_DIR"

    # Pin the daemon's control socket onto tmpfs (see above). MeshConfig is
    # #[serde(default)], so this minimal config.json loads fine and the daemon
    # preserves control_socket across its own config saves. Only (re)write it if
    # it's missing or doesn't already pin the socket, so we don't clobber a
    # daemon- or operator-managed config.
    if [ ! -f "$CONFIG" ] || ! grep -q control_socket "$CONFIG" 2>/dev/null; then
        printf '%s\n' "{\"daemon\":{\"control_socket\":\"$CONTROL_SOCKET\"}}" > "$CONFIG"
    fi

    cp "$DAEMON_SRC" "$DAEMON_DST"
    chmod +x "$DAEMON_DST"

    # Launch the daemon detached. `serve` is the MyOwnMesh daemon subcommand
    # (crates/myownmesh Command::Serve); it serves $MYOWNMESH_HOME/daemon.sock.
    "$DAEMON_DST" serve >/var/log/myownmesh.log 2>&1 &
    echo "myownmesh started (home=$MYOWNMESH_HOME, socket=$CONTROL_SOCKET)"
    ;;

  stop)
    killall myownmesh 2>/dev/null
    rm -rf /tmp/myownmesh
    echo "OK"
    ;;

  restart)
    "$0" stop
    sleep 1
    "$0" start
    ;;

  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
